# Tier: dev | qa | uat | production (loads .env.<APP_ENV> after .env when present)
APP_ENV=dev
ENVIRONMENT=development

PORT=8000

# Browser origins allowed for the Next.js app (comma-separated). Default covers local dev.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

LOG_LEVEL=
LOG_FILE=logs/log.txt

# Same as auth_service — PASETO v4.public (Paserk). Verify-only.
PASETO_PUBLIC_KEY=k4.public.YOUR_PUBLIC_PASERK_HERE

# OpenAI (JD parsing)
OPENAI_API_KEY=

# PostgreSQL — copy DATABASE_URL from auth_service/.env (shared Neon DB for auth user lookup)
DATABASE_URL=
